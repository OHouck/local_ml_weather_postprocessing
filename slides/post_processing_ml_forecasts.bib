@article{jacques-dumasDeepLearningBasedExtreme2022,
  title = {Deep {{Learning-Based Extreme Heatwave Forecast}}},
  author = {{Jacques-Dumas}, Val{\'e}rian and Ragone, Francesco and Borgnat, Pierre and Abry, Patrice and Bouchet, Freddy},
  year = 2022,
