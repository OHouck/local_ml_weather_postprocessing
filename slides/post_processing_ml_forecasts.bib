@article{huaImprovingMediumRangeSevere2026,
  title = {Improving {{Medium-Range Severe Weather Prediction}} through {{Transformer Postprocessing}} of {{AI Weather Forecasts}}},
  author = {Hua, Zhanxiang and Sobash, Ryan A. and Gagne, David John and Sha, Yingkai and {Anderson-Frey}, Alexandra},
  year = 2026,
  month = jan,
  journal = {Artificial Intelligence for the Earth Systems},
  volume = {5},
  number = {1},
  pages = {250045},
  issn = {2769-7525},
  doi = {10.1175/AIES-D-25-0045.1},
  urldate = {2026-05-27},
  abstract = {Abstract             Improving the skill of medium-range (3--8-day) severe weather prediction is crucial for mitigating societal impacts. This study introduces a novel approach leveraging decoder-only transformer networks to postprocess artificial intelligence (AI)-based weather forecasts, specifically from the Pangu-Weather model, for improved severe weather guidance. Unlike traditional postprocessing methods that use a dense neural network to predict the probability of severe weather using discrete forecast samples, our method treats forecast lead times as sequential ``tokens,'' enabling the transformer to learn complex temporal relationships within the evolving atmospheric state. We compare this approach against postprocessing of the Global Forecast System (GFS) using both a traditional dense neural network and our transformer, as well as configurations that exclude convective parameters to fairly evaluate the impact of using the Pangu-Weather AI model. Results demonstrate that the transformer-based postprocessing significantly enhances forecast skill compared to dense neural networks. Furthermore, AI-driven forecasts, particularly Pangu-Weather initialized from high-resolution analysis, exhibit superior performance to GFS in the medium range, even without explicit convective parameters. Our approach offers improved accuracy, and reliability, which also provides interpretability through feature attribution analysis, advancing medium-range severe weather prediction capabilities.                            Significance Statement               This research aims to improve the prediction of general severe weather events, such as tornadoes, hail, and damaging winds, for forecasts made 3--8 days in advance. Our approach uses an advanced artificial intelligence (AI) technique, inspired by large language models, to refine severe weather predictions based on weather forecasts generated from AI weather models. We found this method can substantially boost forecast accuracy, in some cases nearly doubling prediction skill compared to simpler deep learning techniques. More accurate and earlier warnings give communities crucial extra time to prepare, potentially reducing the devastating impacts of severe storms and saving lives.},
  copyright = {http://www.ametsoc.org/PUBSReuseLicenses},
  file = {/Users/ohouck/Zotero/storage/3CIINK4K/aies-AIES-D-25-0045.1.pdf;/Users/ohouck/Zotero/storage/CIQL33IG/Hua et al. - 2026 - Improving Medium-Range Severe Weather Prediction through Transformer Postprocessing of AI Weather Fo.pdf}
}

@misc{huangSnapshotEnsemblesTrain2017,
